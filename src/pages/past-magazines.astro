---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allMagazines = await getCollection('past-magazines');
const sortedMagazines = allMagazines.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title="Past Magazines"
  description="Browse the full archive of E-Sparkman Magazine past editions."
>

  <section class="py-16 px-6" style="background-color: var(--color-black);">
    <div class="mx-auto" style="max-width: var(--max-width);">

      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold);">
        Archive
      </p>
      <h1
        class="text-4xl font-bold mb-12"
        style="font-family: var(--font-display); color: var(--color-white);"
      >
        Past Editions
      </h1>

      {sortedMagazines.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
          {sortedMagazines.map(mag => (
            <a
              href={mag.data.flipUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group block"
              aria-label={`Read ${mag.data.title} - ${mag.data.edition}`}
            >
              <div class="rounded overflow-hidden shadow transition-transform group-hover:-translate-y-1">
                <img
                  src={mag.data.coverImage}
                  alt={`${mag.data.title} - ${mag.data.edition} cover`}
                  class="w-full aspect-[3/4] object-cover"
                  loading="lazy"
                />
              </div>
              <p
                class="text-xs font-semibold text-center mt-2 group-hover:text-[var(--color-gold)] transition-colors"
                style="color: var(--color-white);"
              >
                {mag.data.edition}
              </p>
              <p class="text-xs text-center" style="color: #666;">{mag.data.title}</p>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-center py-24" style="color: #666;">
          The archive is being built. Check back soon.
        </p>
      )}

    </div>
  </section>

</BaseLayout>
