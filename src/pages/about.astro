---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Learn about E-Sparkman Magazine, Publisher Marilyn Parker, and our mission to serve the St. Louis faith community."
>

  <section class="py-16 px-6" style="background-color: var(--color-cream);">
    <div class="mx-auto max-w-3xl">

      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold);">
        Our Story
      </p>
      <h1
        class="text-4xl font-bold mb-8"
        style="font-family: var(--font-display); color: var(--color-black);"
      >
        About E-Sparkman Magazine
      </h1>

      <!-- Mission -->
      <div class="prose prose-lg max-w-none mb-12" style="color: var(--color-black);">
        <p>
          Sparkman Magazine is a family-owned, free digital publication dedicated to serving the
          Christian community. We publish articles to inspire and encourage, deliver information
          through community engagement, innovation, and new media — covering mental health,
          employment, education, awareness campaigns, and community forums.
        </p>
        <p>
          Our magazine is freely accessible on smartphones, laptops, and tablets, reaching
          readers across the St. Louis metro area and beyond.
        </p>
      </div>

      <!-- Publisher bio -->
      <div
        class="rounded-lg p-8 mb-12"
        style="background-color: var(--color-white); border-left: 4px solid var(--color-gold);"
      >
        <h2
          class="text-2xl font-bold mb-4"
          style="font-family: var(--font-display); color: var(--color-black);"
        >
          Marilyn Parker — Publisher & CEO
        </h2>
        <p class="leading-relaxed" style="color: var(--color-gray);">
          Marilyn Parker is the Publisher and CEO of E-Sparkman Magazine. With deep roots in the
          St. Louis faith community, she has guided the magazine's mission of uplifting and
          informing readers since its founding.
        </p>
      </div>

      <!-- In memoriam -->
      <div
        class="rounded-lg p-8"
        style="background-color: var(--color-charcoal); color: var(--color-white);"
      >
        <h2
          class="text-2xl font-bold mb-4"
          style="font-family: var(--font-display); color: var(--color-gold);"
        >
          In Memory: Dr. Bessie Reece
        </h2>
        <p class="leading-relaxed" style="color: #CCC;">
          E-Sparkman Magazine was co-founded by Dr. Bessie Reece, who served as Founding Partner
          from June 1999 until her passing in February 2020. Her vision, faith, and dedication
          remain woven into every page of this publication. We honor her legacy through our
          continued commitment to the community she loved.
        </p>
      </div>

    </div>
  </section>

</BaseLayout>
