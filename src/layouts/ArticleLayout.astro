---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  author: string;
  authorImage?: string;
  date: Date;
  category: string;
  excerpt: string;
  image?: string;
}

const { title, author, authorImage, date, category, excerpt, image } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);

const categoryLabel: Record<string, string> = {
  'faith': 'Faith',
  'job-talk': 'Job Talk',
  'community-care': 'Community Care',
  'testimonies': 'Testimonies',
  'black-history': 'Black History',
  'technology': 'Technology',
};
---

<BaseLayout title={title} description={excerpt} image={image}>
  <article class="max-w-3xl mx-auto px-6 py-12">

    <!-- Category tag -->
    <div class="mb-4">
      <a
        href={`/${category}`}
        class="text-sm font-semibold uppercase tracking-widest"
        style="color: var(--color-gold);"
      >
        {categoryLabel[category] ?? category}
      </a>
    </div>

    <!-- Title -->
    <h1
      class="text-4xl font-bold leading-tight mb-6"
      style="font-family: var(--font-display); color: var(--color-black);"
    >
      {title}
    </h1>

    <!-- Author + date -->
    <div class="flex items-center gap-4 mb-8 pb-8 border-b" style="border-color: var(--color-gray-light);">
      {authorImage && (
        <img
          src={authorImage}
          alt={author}
          class="w-12 h-12 rounded-full object-cover"
        />
      )}
      <div>
        <p class="font-semibold" style="color: var(--color-black);">{author}</p>
        <p class="text-sm" style="color: var(--color-gray);">{formattedDate}</p>
      </div>
    </div>

    <!-- Hero image -->
    {image && (
      <img
        src={image}
        alt={title}
        class="w-full rounded-lg mb-10 object-cover max-h-96"
      />
    )}

    <!-- Article body -->
    <div
      class="prose prose-lg max-w-none"
      style="font-family: var(--font-body); color: var(--color-black);"
    >
      <slot />
    </div>

  </article>
</BaseLayout>
