---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: any;
}

const { href, variant = 'primary', size = 'md', class: className, ...rest } = Astro.props;

const base = 'inline-block font-semibold rounded transition-all hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2';

const sizes = {
  sm: 'py-1.5 px-4 text-sm',
  md: 'py-2 px-5 text-sm',
  lg: 'py-3 px-8 text-base',
};

const variants = {
  primary: `style="background-color: var(--color-gold); color: var(--color-black);"`,
  secondary: `style="background-color: var(--color-red); color: var(--color-white);"`,
  outline: `style="border: 2px solid var(--color-gold); color: var(--color-gold); background: transparent;"`,
};

const classes = [base, sizes[size], className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} set:html={undefined} {...rest} style={
    variant === 'primary' ? 'background-color: var(--color-gold); color: var(--color-black);' :
    variant === 'secondary' ? 'background-color: var(--color-red); color: var(--color-white);' :
    'border: 2px solid var(--color-gold); color: var(--color-gold); background: transparent;'
  }>
    <slot />
  </a>
) : (
  <button class={classes} {...rest} style={
    variant === 'primary' ? 'background-color: var(--color-gold); color: var(--color-black);' :
    variant === 'secondary' ? 'background-color: var(--color-red); color: var(--color-white);' :
    'border: 2px solid var(--color-gold); color: var(--color-gold); background: transparent;'
  }>
    <slot />
  </button>
)}
